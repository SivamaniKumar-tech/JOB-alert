# Copy to .env for local testing.  Do NOT commit your real .env.

# Adzuna (optional but recommended) -- free key from https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Email sending. For Gmail, SMTP_PASS must be an "App Password"
# (Google Account > Security > 2-Step Verification > App passwords),
# NOT your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=youraddress@gmail.com
EMAIL_TO=youraddress@gmail.com

# Set to 1 to print the digest instead of emailing it.
DRY_RUN=0
